# =============================================================
# OS — macOS
# =============================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# =============================================================
# OS — Linux
# =============================================================

.Trash-*
# NFS lock files
.nfs*
# KDE/Dolphin folder settings
.directory

# =============================================================
# OS — Windows
# =============================================================

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================
# Editors — Vim / Neovim
# =============================================================

*.swp
*.swo
*.swn
*~
.netrwhist
Session.vim
# ctags / universal-ctags
tags
.tags

# =============================================================
# Editors — Emacs
# =============================================================

*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
.org-id-locations

# =============================================================
# Editors — VS Code
# =============================================================

# .vscode/ is debated — extensions.json and settings.json
# are often committed for team consistency.
# Ignore only the personal/local files:
.vscode/settings.json
.vscode/*.code-workspace
# often machine-specific paths
.vscode/launch.json
# Local History extension
.history/

# =============================================================
# Editors — JetBrains (IntelliJ, CLion, etc.)
# =============================================================

# .idea/ is debated — some files are worth committing.
# The safe ignore-only list:
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf
.idea/**/httpRequests
.idea/**/dataSources/
.idea/**/dataSources.ids
.idea/**/dataSources.local.xml
.idea/**/sqlDataSources.xml
.idea/**/dynamic.xml
.idea/**/uiDesigner.xml
.idea/**/dbnavigator.xml
.idea/**/gradle.xml
.idea/caches/
*.iws
out/

# =============================================================
# Editors — Helix
# =============================================================

# Helix writes no project-level files — nothing to ignore.
# Session/history lives in ~/.cache/helix/

# =============================================================
# General temp / crash files
# =============================================================

*.tmp
*.temp
*.bak
*.orig
# patch reject files
*.rej
*.log
# core dumps
core
core.*
# Valgrind
vgcore.*
*.pid
*.seed
*.stackdump

# =============================================================
# Secrets & keys — never commit these
# =============================================================

# Generic secret files
.env
.env.*
!.env.example
!.env.template

# Private keys (various formats)
*.pem
*.key
*.p12
*.pfx
*.p8
*.der

# SSH
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
# optional — pub keys are safe, but some prefer to keep the pair together and ignore both
*.pub

# GPG / age
*.gpg
secring.*
trustdb.gpg
# *.age             # don't ignore — age files are the encrypted form,
                    # safe to commit (what sops-nix produces)

# Certificates
*.crt
*.cer
*.ca-bundle

# API keys / tokens / credentials files
*credentials*
*token*
*secret*
*.secrets
auth.json
credentials.json
# GCP service accounts
service-account*.json

# AWS
# .aws/config is usually safe to commit
.aws/credentials
*.aws

# Vault / sops
# *.enc.yaml → safe to commit (encrypted by sops)
# secrets.yaml (plaintext) → never commit
secrets.yaml
secrets.json
secrets.toml
# decrypted output files
*.dec

# HashiCorp Vault tokens
.vault-token

# kubeconfig (contains cluster credentials)
kubeconfig
kubeconfig.*
*.kubeconfig
# $KUBECONFIG is often ~/.kube/config, but if in-repo, ignore it

# Terraform
# often contains secrets
*.tfvars
# *.tfvars.json       # same
# terraform.tfstate   # contains sensitive resource data
# .terraform/         # local plugin cache, not secrets but large

# JWTs / bearer tokens in files
*.jwt

# =============================================================
# Nix
# =============================================================

# Build outputs — symlinks nix build creates in the project root
result
result-*

# =============================================================
# direnv
# =============================================================

# Local direnv cache — machine-specific, rebuilt automatically
.direnv/

# .envrc — debated, but generally commit it if it just says
# "use flake" or "use devenv"; ignore if it has personal env vars.
# Common pattern: commit .envrc, gitignore .envrc.local
.envrc.local

# =============================================================
# AI agent metadata
# Generated by tooling, personal overrides, or externally managed
# =============================================================

# -------------------------------------------------------------
# Aider
# -------------------------------------------------------------

# Aider adds these itself on first run, but explicit is better
# Chat log, readline history, repo-map tag cache
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v*/

# ---------------------------------------------------------------
# Skills — externally managed (synced by tooling, not owned here)
# ---------------------------------------------------------------

# Cross-agent standard — Amp (primary), Codex, Gemini CLI, Cursor,
# OpenCode, Copilot, Cline, Warp, Antigravity, and most others
.agents/skills/

# Holdouts that don't read .agents/skills/
.claude/skills/
.kiro/skills/
.factory/skills/

# ---------------------------------------------------------------
# Harness — auto-generated by setup commands
# ---------------------------------------------------------------

# entire — generated by `nix run .#setup-entire`
.entire/

# gstack — generated by `nix run .#setup-gstack`
.gstack/

# ---------------------------------------------------------------
# Amp
# ---------------------------------------------------------------
# .amp/settings.json  → COMMIT (shared MCP servers, permissions)
# .amp/tools/         → COMMIT if team-shared, else add below
# Amp code-review checks (if externally managed)
.agents/checks/

# ---------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------
# .claude/settings.json  → COMMIT (shared permissions, hooks)
# CLAUDE.md              → COMMIT
.claude/settings.local.json
CLAUDE.local.md

# ---------------------------------------------------------------
# Kiro
# ---------------------------------------------------------------
# .kiro/skills/    → COMMIT (team shared)
# .kiro/steering/  → COMMIT (team shared)
# .kiro/agents/    → COMMIT (team shared)
# (no personal override files doc
